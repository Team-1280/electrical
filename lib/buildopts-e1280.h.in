#pragma once

#include <string_view>
#include <type_traits>

namespace e1280_lib {

struct BuildOpts {
    static constexpr const std::string_view build_type_str = "@CMAKE_BUILD_TYPE@";
    /**
     * @brief An enum describing the current build type set by CMake
     */
    enum class BuildType {
        Debug,
        RelWithDebInfo,
        Release,
        MinSizeRel
    };

    static consteval bool should_log_trace() {
        return build_type == BuildType::RelWithDebInfo || build_type == BuildType::Debug;
    }

    static constexpr const BuildType build_type = BuildType::@CMAKE_BUILD_TYPE@;
    static constexpr const std::size_t version_major = @CMAKE_PROJECT_VERSION_MAJOR@;
    static constexpr const std::size_t version_minor = @CMAKE_PROJECT_VERSION_MINOR@;
    static constexpr const std::size_t version_patch = @CMAKE_PROJECT_VERSION_PATCH@;
    static constexpr const std::string_view version_str = "@CMAKE_PROJECT_VERSION@";
};

}
